generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Registrations {
  id               Int      @id @default(autoincrement())
  status           Int      @db.UnsignedTinyInt
  name             String   @db.VarChar(50)
  email            String   @db.VarChar(50)
  telephone        String   @db.VarChar(50)
  address          String   @db.MediumText
  donate           Int      @db.UnsignedTinyInt @default(0)
  donateAmount     Decimal  @db.Decimal(8, 2) 
  singlePinAmount  Int      @db.UnsignedInt
  pinSetAmount     Int      @db.UnsignedInt
  receipt          Int      @db.TinyInt
  nationalId       String   @db.VarChar(13)
  receiptName      String   @db.VarChar(50)
  receiptAddress   String   @db.MediumText
  buyShirt         Int      @db.TinyInt
  order            String   @db.MediumText
  transferTime     String   @db.VarChar(255)
  transferDate     String   @db.VarChar(255)
  trackingNumber1  String?  @db.VarChar(255)  
  trackingNumber2  String?  @db.VarChar(255)
  problems         String?  @db.MediumText 
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  allPinAmount     Int      @db.UnsignedInt
}
